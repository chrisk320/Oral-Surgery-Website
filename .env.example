# Resend — powers the contact form email (src/app/api/contact/route.ts)
# Copy to .env.local for local dev, and set the same vars in the Vercel dashboard.

# API key from https://resend.com/api-keys
RESEND_API_KEY=

# Sender address. Must be on a domain verified in Resend
# (e.g. ocimplantoralsurgery.com). Do NOT use onboarding@resend.dev in production.
RESEND_FROM="OC Implant Oral Surgery <noreply@ocimplantoralsurgery.com>"

# Where contact-form inquiries are delivered (the practice's monitored inbox).
RESEND_TO=front-desk@ocimplantoralsurgery.com
